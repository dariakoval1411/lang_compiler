function int fun_1() { 
  return 42;
}

function real add(int a, int b) {
  return a + b;
}

function int minus(int a, int b) {
  return a - b;
}

function int x_sum(int a, int b,int c) { 

    while(a < b) {
      c = c + a;
      a = a + 1;
    }
    return c;
}    

function int square(int value) { 
    return value * value;
}

program Main

int y = fun_1();
show(y);
show(add(4,6));
show(minus(6,10));
show(x_sum(2, 8, 0));
show(add(square(4),3));
end